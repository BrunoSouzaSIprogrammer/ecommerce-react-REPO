# ================= PORTA DO SERVIDOR =================
PORT=5000

# ================= CHAVE SECRETA JWT =================
# Gere uma chave forte para produção: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua-chave-secreta-muito-forte-aqui
JWT_EXPIRES_IN=24h

# ================= FIREBASE =================
# O arquivo serviceAccountKey.json deve estar em backend/config/
# NUNCA commitar o arquivo JSON real no GitHub
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_CLIENT_EMAIL=seu-client-email
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nSUA-CHAVE-PRIVADA\n-----END PRIVATE KEY-----\n

# ================= CONFIGURAÇÕES DE COMISSÃO =================
# Porcentagem padrão que vai para o ADMIN (1-100)
COMISSAO_PADRAO=5

# ================= PAGAMENTO =================
# Chaves PIX (ambiente sandbox)
PIX_KEY=sua-chave-pix
PIX_CERT_PATH=./config/certificado_pix.pfx
PIX_CLIENT_ID=client_id_do_banco
PIX_CLIENT_SECRET=client_secret_do_banco

# Stripe (cartão de crédito/débito)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
